{
  "name": "ayala-bridge",
  "version": "2.49.1",
  "description": "Bridge for Ayala POS CSV generation",
  "main": "main.js",
  "author": "Ayala Bridge Developer",
  "build": {
    "appId": "com.ayala.bridge",
    "publish": {
      "provider": "github",
      "owner": "JangKarl",
      "repo": "utak-ayala-bridge"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Ayala Bridge",
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "scripts": {
    "start": "electron .",
    "dev": "node -e \"require('./bridge').startServer()\"",
    "build": "electron-builder --win",
    "publish": "electron-builder --win --publish always",
    "test": "node --test test/"
  },
  "keywords": [
    "ayala",
    "pos",
    "bridge"
  ],
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-validator": "^7.2.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.1"
  }
}